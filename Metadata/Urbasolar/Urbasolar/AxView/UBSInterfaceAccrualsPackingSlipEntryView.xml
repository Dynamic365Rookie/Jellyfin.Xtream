]]></Declaration>
		<Methods>
			<Method>
				<Name>getEntryType</Name>
				<Source><![CDATA[
    public static str getEntryType()
    {
        return SysComputedColumn::returnLiteral('FNP');
    }

]]></Source>
			</Method>
			<Method>
				<Name>getTransactionCurrencyAmount</Name>
				<Source><![CDATA[
    public static str getTransactionCurrencyAmount()
    {
        str ret = SysComputedColumn::if(
            SysComputedColumn::compareExpressions(
                SysComputedColumn::returnField(viewstr(UBSInterfaceAccrualsPackingSlipEntryView),tableStr(SubledgerJournalAccountEntryDistribution),fieldStr(SubledgerJournalAccountEntryDistribution,AccountingCurrencyAmount)),
                    '>',
                SysComputedColumn::returnLiteral(0)
                ),
            SysComputedColumn::abs(
                    SysComputedColumn::returnField(viewstr(UBSInterfaceAccrualsPackingSlipEntryView),tableStr(AccountingDistribution),fieldStr(AccountingDistribution,TransactionCurrencyAmount))
            ),
                SysComputedColumn::multiply('-1',
                    SysComputedColumn::abs(
                        SysComputedColumn::returnField(viewstr(UBSInterfaceAccrualsPackingSlipEntryView),tableStr(AccountingDistribution),fieldStr(AccountingDistribution,TransactionCurrencyAmount))
                    )
                )
            );

        return ret;
    }

]]></Source>
			</Method>
		</Methods>
