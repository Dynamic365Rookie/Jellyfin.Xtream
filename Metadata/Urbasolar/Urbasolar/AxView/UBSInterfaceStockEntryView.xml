		<Methods>
			<Method>
				<Name>getEntryType</Name>
				<Source><![CDATA[
    public static str getEntryType()
    {
        str ret;
        Map inventTransTypeMap = new Map(Types::String, Types::String);

        inventTransTypeMap.insert(int2str(enum2int(InventTransType::Sales)),SysComputedColumn::returnLiteral("Vente"));
        inventTransTypeMap.insert(int2str(enum2int(InventTransType::Purch)),SysComputedColumn::returnLiteral("Achat"));
        inventTransTypeMap.insert(int2str(enum2int(InventTransType::InventTransaction)),SysComputedColumn::returnLiteral("Rebut"));
        inventTransTypeMap.insert(int2str(enum2int(InventTransType::InventTransfer)),SysComputedColumn::returnLiteral("Transfert"));
        inventTransTypeMap.insert(int2str(enum2int(InventTransType::InventLossProfit)),SysComputedColumn::returnLiteral("Ajustement"));
        inventTransTypeMap.insert(int2str(enum2int(InventTransType::InventCounting)),SysComputedColumn::returnLiteral("InvenTaire"));


        ret = SysComputedColumn::switch(
            SysComputedColumn::returnField(viewstr(UBSInterfaceStockEntryView),viewstr(UBSVoucherStockReferenceCategoryView),fieldStr(UBSVoucherStockReferenceCategoryView,ReferenceCategory)),
            inventTransTypeMap,
            SysComputedColumn::returnLiteral("Autre")
            );

        return ret;
    }

]]></Source>
			</Method>
		</Methods>
