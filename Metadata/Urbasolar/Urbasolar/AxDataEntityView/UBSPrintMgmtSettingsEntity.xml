		<Methods>
			<Method>
				<Name>postGetStagingData</Name>
				<Source><![CDATA[
    public static void postGetStagingData(DMFDefinitionGroupExecution _dmfDefinitionGroupExecution)
    {

        UBSPrintMgmtSettingsStaging staging;

        while select forupdate staging where staging.DefinitionGroup == _dmfDefinitionGroupExecution.DefinitionGroup
                && staging.ExecutionId == _dmfDefinitionGroupExecution.ExecutionId
                && staging.TransferStatus == DMFTransferStatus::NotStarted
        {
            ttsbegin;
            staging.PrintMgmtSettings_Description = "Default";
            staging.doUpdate();
            ttscommit;
        }
    }

]]></Source>
			</Method>
			<Method>
				<Name>postTargetProcess</Name>
				<Source><![CDATA[
    public static void postTargetProcess(DMFDefinitionGroupExecution _dmfDefinitionGroupExecution)
    {
        //check if import job is finished
        if (_dmfDefinitionGroupExecution.StagingStatus == DMFBatchJobStatus::Finished)
        {
            UBSPrintMgmtSettingsStaging staging;
 
            //select all staging records that were processed by current execution job without errors.
            while select staging
            where staging.DefinitionGroup == _dmfDefinitionGroupExecution.DefinitionGroup
               && staging.ExecutionId     == _dmfDefinitionGroupExecution.ExecutionId
               && staging.TransferStatus  == DMFTransferStatus::Completed
            {
                
                PrintMgmtSettings printMgmtSettings;
                PrintMgmtDocInstance printMgmtDocInstance;

                select firstonly forupdate printMgmtSettings
                    join printMgmtDocInstance where printMgmtDocInstance.RecId == printMgmtSettings.ParentId
                    && printMgmtDocInstance.DocumentType == staging.printMgmtDocInstance_DocumentType
                    && printMgmtDocInstance.Name == staging.printMgmtDocInstance_Name
                    && printMgmtSettings.PriorityId == staging.PrintMgmtSettings_PriorityId;

                ERTextFormatTable textFormat;
                ERFormatDestinationTable formatDestinationTable;
                ERFormatDestinationNamedTable DestinationNameTable;

                select firstonly DestinationNameTable
                    join formatDestinationTable where DestinationNameTable.FormatDestination == formatDestinationTable.RecId
                    join textFormat where formatDestinationTable.Format == textFormat.RecId
                    && textFormat.Name == staging.Format_Name
                    && textFormat.Solution == staging.Format_Solution
                    && DestinationNameTable.Name == staging.DestinationNamedTable_Name;
                
                if(printMgmtSettings && DestinationNameTable)
                {
                    ttsbegin;
                    printMgmtSettings.NamedDestination = DestinationNameTable.RecId;
                    printMgmtSettings.doUpdate();
                    ttscommit;
                }
            }
        }
    }

]]></Source>
			</Method>
