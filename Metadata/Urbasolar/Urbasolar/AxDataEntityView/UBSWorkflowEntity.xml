		<Methods>
			<Method>
				<Name>postGetStagingData</Name>
				<Source><![CDATA[
    public static void postGetStagingData(DMFDefinitionGroupExecution _dmfDefinitionGroupExecution)
    {
        UBSWorkflowStaging UBSWorkflowStaging;
        UBSVendParametersCC vendParametersCC = UBSVendParametersCC::find();
        NumberSequenceCode WFNumSeq = vendParametersCC.WorkflowNumberSequence;
        NumberSeq numberSeq;
        NumberSequenceTable NumSeqTable;
        select firstonly NumSeqTable where NumSeqTable.NumberSequence == WFNumSeq;
        

        if(WFNumSeq)
        {
            while select forupdate UBSWorkflowStaging where UBSWorkflowStaging.DefinitionGroup == _dmfDefinitionGroupExecution.DefinitionGroup
                && UBSWorkflowStaging.ExecutionId == _dmfDefinitionGroupExecution.ExecutionId
                && UBSWorkflowStaging.TransferStatus == DMFTransferStatus::NotStarted
            {
                
                numberSeq = NumberSeq::newGetNumFromId(NumSeqTable.RecId);
                ttsbegin;
                UBSWorkflowStaging.SequenceNumber = numberSeq.num();
                UBSWorkflowStaging.doUpdate();
                numberSeq.used();
                ttscommit;

                
            }
        }
    }

]]></Source>
			</Method>
		</Methods>
	</SourceCode>
