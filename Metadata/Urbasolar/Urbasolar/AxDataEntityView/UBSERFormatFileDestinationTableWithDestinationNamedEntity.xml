		<Methods>
			<Method>
				<Name>postTargetProcess</Name>
				<Source><![CDATA[
    public static void postTargetProcess(DMFDefinitionGroupExecution _dmfDefinitionGroupExecution)
    {
        //check if import job is finished
        if (_dmfDefinitionGroupExecution.StagingStatus == DMFBatchJobStatus::Finished)
        {
            UBSERFormatFileDestinationTableWithDestinationNamedStaging staging;
 
            //select all staging records that were processed by current execution job without errors.
            while select staging
            where staging.DefinitionGroup == _dmfDefinitionGroupExecution.DefinitionGroup
               && staging.ExecutionId     == _dmfDefinitionGroupExecution.ExecutionId
               && staging.TransferStatus  == DMFTransferStatus::Completed
            {

                ERFormatFileDestinationTable formatFileDestinationTable;
                ERFormatDestinationTable formatDestinationTable;
                ERTextFormatTable textFormat;

                select forupdate firstonly formatFileDestinationTable
                    join formatDestinationTable where formatFileDestinationTable.FormatDestination == formatDestinationTable.RecId
                    join textFormat where formatDestinationTable.Format == textFormat.RecId
                    && textFormat.Name == staging.Format_Name
                    && textFormat.Solution == staging.Format_Solution
                    && formatFileDestinationTable.Name == staging.Name
                    && formatFileDestinationTable.FileGuid == staging.FileGuid;

                ERFormatDestinationSettings destinationSettings = formatFileDestinationTable.getSettings();
                DictClass dictClass = new DictClass(className2Id("ERFormatDestinationFileSettings"));

                var ERFormatDestinationFileSettings = dictClass.callStatic("create", conNull());
                dictClass.callObject("setEnabled", ERFormatDestinationFileSettings, true);

                destinationSettings.addSettings(ERFormatDestinationFileSettings);

                ttsbegin;

                if(destinationSettings)
                {
                    
                    formatFileDestinationTable.saveSettings(destinationSettings);
                }

                formatFileDestinationTable.doUpdate();
                ttscommit;
            }
        }
    }

]]></Source>
			</Method>
		</Methods>
