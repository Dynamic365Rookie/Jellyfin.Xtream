		<Methods>
			<Method>
				<Name>insertEntityDataSource</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <param name = "_entityCtx"></param>
    /// <param name = "_dataSourceCtx"></param>
    /// <returns></returns>
    public boolean insertEntityDataSource(DataEntityRuntimeContext _entityCtx, DataEntityDataSourceRuntimeContext _dataSourceCtx)
    {
        boolean ret;
    
        ret = super(_entityCtx, _dataSourceCtx);

        if(this.IsEnable && this.FeatureSetupId)
        {
            this.synchronizeTaxServiceData();
        }

        if(this.PurchaseModuleEnabled)
        {
            TaxIntegrationBusinessProcessTable bPTable;

            bPTable.BusinessProcess = TaxIntegrationBusinessProcess::Purchase;
            bPTable.SolutionProviderType = TaxSolutionProviderType::Microsoft;
            bPTable.insert();
        }
    
        return ret;
    }

]]></Source>
			</Method>
			<Method>
				<Name>updateEntityDataSource</Name>
				<Source><![CDATA[
    /// <summary>
    ///
    /// </summary>
    /// <param name = "_entityCtx"></param>
    /// <param name = "_dataSourceCtx"></param>
    /// <returns></returns>
    public boolean updateEntityDataSource(DataEntityRuntimeContext _entityCtx, DataEntityDataSourceRuntimeContext _dataSourceCtx)
    {
        boolean ret;
    
        ret = super(_entityCtx, _dataSourceCtx);

        if(this.IsEnable && (!this.orig().IsEnable || this.FeatureSetupId != this.orig().FeatureSetupId 
                            || this.FeatureSetupName != this.orig().FeatureSetupName
                            || this.FeatureSetupVersion != this.orig().FeatureSetupVersion))
        {
            this.synchronizeTaxServiceData();
        }

        TaxIntegrationBusinessProcessTable bPTable;

        delete_from bPTable where bPTable.BusinessProcess == TaxIntegrationBusinessProcess::Purchase  && bPTable.SolutionProviderType == TaxSolutionProviderType::Microsoft;

        if(this.PurchaseModuleEnabled)
        {
            bPTable.BusinessProcess = TaxIntegrationBusinessProcess::Purchase;
            bPTable.SolutionProviderType = TaxSolutionProviderType::Microsoft;
            bPTable.insert();
        }
    
        return ret;
    }

]]></Source>
			</Method>
			<Method>
				<Name>synchronizeTaxServiceData</Name>
				<Source><![CDATA[
    protected void synchronizeTaxServiceData()
    {
        DictClass syncDictClass = new DictClass(className2Id("TaxIntegrationTaxServiceDataSynchronizer"));
        container argStatic = [this.FeatureSetupId,this.FeatureSetupName,this.FeatureSetupVersion];

        var syncClass = syncDictClass.callStatic("constructWithParameterTable",this.FeatureSetupId,this.FeatureSetupVersion,this.FeatureSetupName);

        syncDictClass.callObject("parmSolutionProviderType",syncClass,TaxSolutionProviderType::Microsoft);

        syncDictClass.callObject("synchronize",syncClass);

    }

]]></Source>
			</Method>
			<Method>
				<Name>getIsPurchaseProcessActive</Name>
				<Source><![CDATA[
    public static str getIsPurchaseProcessActive()
    {
         str ret = strFmt(@" select 1 from %1 
                                where %1.%2 = %3 and %1.%4 = %5 and %1.%6 = %7
                            ",tableStr(TaxIntegrationBusinessProcessTable)
                             ,fieldStr(TaxIntegrationBusinessProcessTable,BusinessProcess)
                            ,enum2int(TaxIntegrationBusinessProcess::Purchase)
                            ,fieldStr(TaxIntegrationBusinessProcessTable,SolutionProviderType)
            ,enum2int(TaxSolutionProviderType::Microsoft)
             ,fieldStr(TaxIntegrationBusinessProcessTable,DataAreaId),
             SysComputedColumn::returnField(viewstr(UBSTaxServiceParametersEntity),tableStr(TaxIntegrationTaxServiceParameters),fieldStr(TaxIntegrationTaxServiceParameters,DataAreaId)));

        return ret;
    }

]]></Source>
			</Method>
		</Methods>
