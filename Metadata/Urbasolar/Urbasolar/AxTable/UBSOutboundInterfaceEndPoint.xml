				<Source><![CDATA[
    public static UBSOutboundInterfaceEndPoint findByEndPointType(UBSEndPointType _endPointType)
    {
        UBSOutboundInterfaceEndPoint outboundInterfaceEndPoint;

        select firstfast outboundInterfaceEndPoint where outboundInterfaceEndPoint.UBSEndPointType == _endPointType;

        return outboundInterfaceEndPoint;
    }

]]></Source>
