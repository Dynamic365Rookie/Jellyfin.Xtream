			<Method>
				<Name>updateUBSOutboundInterfaceEndPointSynchronisationDate</Name>
				<Source><![CDATA[
    public static void updateUBSOutboundInterfaceEndPointSynchronisationDate(UBSEndPointType _ubsEndPointType)
    {
        UBSOutboundInterfaceEndPoint outboundInterfaceEndPoint;

        ttsbegin;
        select firstonly forupdate outboundInterfaceEndPoint 
            where outboundInterfaceEndPoint.UBSEndPointType == _ubsEndPointType;

        outboundInterfaceEndPoint.UBSLastSynchronisationDateTime = DateTimeUtil::utcNow();
        outboundInterfaceEndPoint.update();
        ttscommit;
    }

]]></Source>
