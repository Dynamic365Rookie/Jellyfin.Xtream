		<Methods>
			<Method>
				<Name>checkReferencingDocument</Name>
				<Source><![CDATA[
    public static boolean checkReferencingDocument(RefRecId _party) 
    {
        boolean                 ret                  = true;
        UBSReferencingDocuments referencingDocuments = UBSReferencingDocuments::findNotReferencingDocument(_party);

        if(referencingDocuments)
        {
            ret = checkFailed('@UBS:UBSMissingDocumentInVendor');
        }

        return ret;
    }

]]></Source>
			</Method>
			<Method>
				<Name>findNotReferencingDocument</Name>
				<Source><![CDATA[
    public static UBSReferencingDocuments findNotReferencingDocument(RefRecId _party)
    {
        UBSReferencingDocuments referencingDocuments;

        if(!VendParameters::find().UBSDisableReferencingCheck)
        {
            select firstfast referencingDocuments
                where referencingDocuments.UBSDocumentName =='' &&
                      referencingDocuments.Party == _party;
        }

        return referencingDocuments;
    }

]]></Source>
			</Method>
		</Methods>
