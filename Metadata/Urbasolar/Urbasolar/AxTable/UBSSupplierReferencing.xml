		<Methods>
			<Method>
				<Name>findMinByProcCategory</Name>
				<Source><![CDATA[
    public static UBSSupplierReferencing findMinByProcCategory(str _procCategoryName)
    {
        UBSSupplierReferencing supplierReferencing,
                               supplierReferencingRet;

        select minof(UBSMaximumVolume) from supplierReferencing
            where supplierReferencing.UBSProcCategoryName == _procCategoryName;
           
        select supplierReferencingRet
            where supplierReferencingRet.UBSProcCategoryName == _procCategoryName &&
                  supplierReferencingRet.UBSMaximumVolume == supplierReferencing.UBSMaximumVolume;

        return supplierReferencingRet;
    }

]]></Source>
