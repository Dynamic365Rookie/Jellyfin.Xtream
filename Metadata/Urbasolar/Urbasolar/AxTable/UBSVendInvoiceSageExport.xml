    public static void resetExportState(RefRecId _VendInvoiceJourRecId)
    {
        UBSVendInvoiceSageExport vendInvoiceSageExport;

        select forupdate vendInvoiceSageExport where vendInvoiceSageExport.VendInvoiceJourRecId == _VendInvoiceJourRecId;

        if(vendInvoiceSageExport)
        {
            vendInvoiceSageExport.ExecutionDateTime = utcdatetimenull();
            vendInvoiceSageExport.ErrorMessage = "";
            vendInvoiceSageExport.UBSExportStatus = UBSExportStatus::ToProcess;
            vendInvoiceSageExport.update();
        }
    }

]]></Source>
